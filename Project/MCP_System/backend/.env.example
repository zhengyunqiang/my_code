# MCP System Environment Configuration
# 环境变量配置模板

# ========================================
# 应用配置
# ========================================
APP_NAME=MCP System
APP_VERSION=1.0.0
DEBUG=true
ENVIRONMENT=development

# ========================================
# 服务器配置
# ========================================
HOST=0.0.0.0
PORT=8000
TRANSPORT_TYPE=http  # stdio, http, both

# ========================================
# CORS 配置
# ========================================
# CORS_ORIGINS=["http://localhost:3000","http://localhost:8000"]
CORS_ALLOW_CREDENTIALS=true

# ========================================
# JWT 配置
# ========================================
SECRET_KEY=your-mcp-secret-key-change-this-in-production-min-32-chars
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440
REFRESH_TOKEN_EXPIRE_DAYS=7

# ========================================
# 数据库配置
# ========================================
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/mcp_db
DATABASE_ECHO=false
DATABASE_POOL_SIZE=10
DATABASE_MAX_OVERFLOW=20

# ========================================
# Redis 配置
# ========================================
REDIS_URL=redis://localhost:6379/0
REDIS_DECODE_RESPONSES=true

# 缓存配置
CACHE_TTL=3600
CACHE_MAX_SIZE=10000

# ========================================
# 速率限制配置
# ========================================
RATE_LIMIT_ENABLED=true
RATE_LIMIT_PER_MINUTE=60
RATE_LIMIT_BURST=10
RATE_LIMIT_WINDOW=60
USER_DAILY_QUOTA=10000
USER_HOURLY_QUOTA=1000

# ========================================
# MCP 协议配置
# ========================================
MCP_PROTOCOL_VERSION=2024-11-05
MCP_SERVER_NAME=mcp-system-server
MCP_SERVER_VERSION=1.0.0
MCP_CAPABILITIES_TOOLS=true
MCP_CAPABILITIES_RESOURCES=true
MCP_CAPABILITIES_PROMPTS=true
MCP_CAPABILITIES_LOGGING=true

# ========================================
# 安全配置
# ========================================
MAX_INPUT_LENGTH=100000
MAX_TOOL_ARGUMENTS_SIZE=100000
PROMPT_INJECTION_ENABLED=true

# ========================================
# 日志配置
# ========================================
LOG_LEVEL=INFO
LOG_FORMAT=json
LOG_OUTPUT=both
LOG_FILE_PATH=logs/mcp_system.log

# ========================================
# Kafka 配置
# ========================================
# KAFKA_BOOTSTRAP_SERVERS=["localhost:9092"]
KAFKA_SECURITY_PROTOCOL=PLAINTEXT
KAFKA_ENABLED=false

# ========================================
# 工具执行配置
# ========================================
TOOL_EXECUTION_TIMEOUT=30
TOOL_MAX_CONCURRENT=10
TOOL_IDEMPOTENCY_ENABLED=true
TOOL_IDEMPOTENCY_TTL=3600

# ========================================
# 资源配置
# ========================================
RESOURCE_CACHE_ENABLED=true
RESOURCE_CACHE_TTL=300
RESOURCE_MAX_SIZE=10485760

# ========================================
# 监控配置
# ========================================
HEALTH_CHECK_ENABLED=true
HEALTH_CHECK_INTERVAL=30
METRICS_ENABLED=true
METRICS_PORT=9090

# ========================================
# 会话配置
# ========================================
SESSION_TIMEOUT=3600
SESSION_MAX_REQUESTS=1000

# ========================================
# 千问 API 配置（用于自然语言数据库操作）
# ========================================
# 获取 API Key: https://bailian.console.aliyun.com/
# 可用模型: qwen-turbo, qwen-plus (推荐), qwen-max
QWEN_API_KEY=your-qwen-api-key-here
QWEN_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
QWEN_MODEL=qwen-plus
QWEN_MAX_TOKENS=4096
QWEN_TEMPERATURE=0.7
