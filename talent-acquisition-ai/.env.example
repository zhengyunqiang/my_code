# Application Settings
APP_NAME=TALENT_ACQUISITION_AI
APP_VERSION=1.0.0
APP_ENV=development
DEBUG=true
SECRET_KEY=your-super-secret-key-change-in-production
# ALLOWED_HOSTS=["localhost","127.0.0.1"]  # 使用默认值，无需设置

# Server Settings
HOST=0.0.0.0
PORT=8000
WORKERS=4

# Database Settings
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/talent_ai
DATABASE_ECHO=false
DATABASE_POOL_SIZE=20
DATABASE_MAX_OVERFLOW=10

# Redis Settings
REDIS_URL=redis://localhost:6379/0
REDIS_PASSWORD=
REDIS_DB=0
REDIS_MAX_CONNECTIONS=50

# Qwen / Dashscope API Settings
QWEN_API_KEY=sk-WwCuZHoVGF
QWEN_MODEL=qwen-max
QWEN_TEMPERATURE=0.7
QWEN_MAX_TOKENS=2000
QWEN_TIMEOUT=60

# RAG Settings
RAG_EMBEDDING_MODEL=text-embedding-v3
RAG_CHUNK_SIZE=500
RAG_CHUNK_OVERLAP=50
RAG_TOP_K=5
RAG_SCORE_THRESHOLD=0.7

# Boss Zhipin RPA Settings
BOSS_USERNAME=your-boss-username
BOSS_PASSWORD=your-boss-password
BOSS_BASE_URL=https://www.zhipin.com
BOSS_HEADLESS=false
BOSS_DOWNLOAD_PATH=/tmp/automation_downloads

# File Storage Settings
UPLOAD_DIR=./static/uploads
MAX_UPLOAD_SIZE=10485760  # 10MB
# ALLOWED_EXTENSIONS=["pdf","doc","docx","txt","jpg","jpeg","png"]  # 使用默认值

# OCR Settings
TESSERACT_CMD=/usr/bin/tesseract
TESSERACT_LANGUAGE=chi_sim+eng

# Logging Settings
LOG_LEVEL=INFO
LOG_DIR=./logs
LOG_ROTATION=500 MB
LOG_RETENTION=30 days

# Celery Settings
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2
CELERY_TASK_SERIALIZER=json
CELERY_RESULT_SERIALIZER=json
# CELERY_ACCEPT_CONTENT=["json"]  # 使用默认值
CELERY_TIMEZONE=Asia/Shanghai
CELERY_ENABLE_UTC=true

# Security Settings
JWT_SECRET_KEY=your-jwt-secret-key
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# Rate Limiting
RATE_LIMIT_ENABLED=true
RATE_LIMIT_PER_MINUTE=60
RATE_LIMIT_PER_HOUR=1000

# Monitoring Settings
SENTRY_DSN=
SENTRY_ENVIRONMENT=development
PROMETHEUS_PORT=9090

# Email Settings (for notifications)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your-email@gmail.com
SMTP_PASSWORD=your-app-password
SMTP_FROM_EMAIL=noreply@talentai.com
SMTP_FROM_NAME=Talent AI System

# WeChat Work Settings (for notifications)
WECHAT_WORK_CORP_ID=
WECHAT_WORK_AGENT_ID=
WECHAT_WORK_AGENT_SECRET=

# External APIs
CHSI_API_URL=https://www.chsi.com.cn  # 学信网
ALIYUN_OCR_ACCESS_KEY_ID=
ALIYUN_OCR_ACCESS_KEY_SECRET=

# Feature Flags
ENABLE_RPA=true
ENABLE_AUTO_JD_OPTIMIZATION=true
ENABLE_TALENT_RECOMMENDATION=true
ENABLE_AUTO_FEEDBACK_COLLECTION=true
